REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
REDIS_UI_PORT=8081
LOG_LEVEL=INFO
LOG_DIR=/app/logs

API_PORT=8000
FRONTEND_PORT=8080

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=		  
# Задержка перед первой отправкой нового события в Telegram.
EVENT_SEND_DELAY_SECONDS=40
# Время без обновлений, после которого событие считается завершённым.
EVENT_EXPIRE_SECONDS=60

EXCHANGES=bybit,binance,kucoin,gateio,bitget,coinex,bingx
EXCHANGE_POLL_INTERVAL_SECONDS=1
ORDERBOOK_TARGET_VALUE=800
ORDERBOOK_MAX_LEVELS=4
BACKEND_RENDER_INTERVAL_SECONDS=0.5
ARBITRAGE_MIN_SPREAD_PERCENT=0.3
SPREAD_THRESHOLD_PCT=0.3
ARBITRAGE_HISTORY_LIMIT=1000
ARBITRAGE_HISTORY_DB_PATH=/data/arbitrage_history.db

ORDERBOOK_REDIS_SYMBOLS_SET_TEMPLATE=orderbook:{exchange}:symbols
ORDERBOOK_REDIS_KEY_PREFIX=orderbook
# Set с ключами активных арбитражных событий.
ARBITRAGE_EVENTS_REDIS_SET_KEY=arbitrage:events:active
# Шаблон Redis Hash ключа для хранения состояния события.
ARBITRAGE_EVENT_REDIS_KEY_TEMPLATE=arbitrage:event:{event_key}

